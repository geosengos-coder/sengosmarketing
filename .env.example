# ------------------------------------------------------------------ Database
# Pooled connection used by the app (RLS-enforced role).
DATABASE_URL="postgresql://operatoros:operatoros@localhost:5432/operatoros?schema=public"
# Direct connection used by Prisma Migrate (no pooler).
DIRECT_URL="postgresql://operatoros:operatoros@localhost:5432/operatoros?schema=public"

# ------------------------------------------------------------------ Clerk (auth only)
# Clerk authenticates USERS. Organizations/roles/permissions live in our DB (ADR-0009).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Signing secret for the Clerk -> DB user-sync webhook (svix).
CLERK_WEBHOOK_SIGNING_SECRET=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# ------------------------------------------------------------------ App
NODE_ENV="development"
