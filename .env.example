# ------------------------------------------------------------------ Database
# Pooled connection used by the app (RLS-enforced role).
DATABASE_URL="postgresql://operatoros:operatoros@localhost:5432/operatoros?schema=public"
# Direct connection used by Prisma Migrate (no pooler).
DIRECT_URL="postgresql://operatoros:operatoros@localhost:5432/operatoros?schema=public"

# ------------------------------------------------------------------ Clerk (auth only)
# Clerk authenticates USERS. Organizations/roles/permissions live in our DB (ADR-0009).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Signing secret for the Clerk -> DB user-sync webhook (svix).
CLERK_WEBHOOK_SIGNING_SECRET=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# ------------------------------------------------------------------ AI (Business DNA generation — ADR-0016)
# OpenAI powers the real Business DNA analyzer. Without it, generation falls back
# to the deterministic HeuristicGenerator automatically.
OPENAI_API_KEY=""
OPENAI_DNA_MODEL=""

# ------------------------------------------------------------------ Voice (live "Talk to Ava" — ADR-0017)
# Retell is the concrete VoiceProvider. Without RETELL_API_KEY, the call experience
# shows an honest "not connected" state rather than a fake conversation.
RETELL_API_KEY=""
RETELL_DEFAULT_VOICE_ID=""
RETELL_LLM_MODEL=""
# Must be a PUBLICLY reachable base URL — Retell calls back to it to execute tools
# mid-call. A bare localhost dev server needs a tunnel (e.g. ngrok) for live tool
# calls (booking, lookup, etc.) to work; without it, session creation still
# succeeds but Ava cannot complete bookings.
PUBLIC_APP_URL=""

# ------------------------------------------------------------------ App
NODE_ENV="development"
